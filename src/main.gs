/**
 * エントリーポイント
 *
 * ・時間トリガー／手動実行のどちらからも呼ばれる
 * ・message単位で処理を行う安全設計
 */
function main() {
  try {
    // ------------------------------------------------------------
    // 処理開始ログ
    // ------------------------------------------------------------
    logStart();

    // ------------------------------------------------------------
    // 設定読み込み
    // ------------------------------------------------------------
    loadConfig();

    // ------------------------------------------------------------
    // Gmail 検索（message単位）
    // ------------------------------------------------------------
    const messages = searchTargetMails();

    if (messages.length === 0) {
      logNoTarget();
      return;
    }

    logInfo(`対象メール数: ${messages.length}`);

    // ------------------------------------------------------------
    // message単位処理
    // ------------------------------------------------------------
    for (const message of messages) {

      const messageId = message.getId();

      // ----------------------------------------------------------
      // 冪等性チェック（既に処理済みならスキップ）
      // ----------------------------------------------------------
      if (isProcessed(messageId)) {
        logInfo(`skip processed message: ${messageId}`);
        continue;
      }

      // ----------------------------------------------------------
      // メール解析
      // ----------------------------------------------------------
      let record;

      try {
        record = parseSingleMail(message);
      } catch (e) {
        logError(`parse failed: ${messageId}`);
        logError(e);
        continue; // 解析失敗はスキップ（全体停止しない）
      }

      if (!record) {
        logWarn(`no record generated: ${messageId}`);
        continue;
      }

      // ----------------------------------------------------------
      // スプレッドシート書き込み
      // ----------------------------------------------------------
      writeToSpreadsheet([record]);

      // ----------------------------------------------------------
      // 処理済み登録（書き込み成功後のみ）
      // ----------------------------------------------------------
      markAsProcessed(messageId);

      logInfo(`processed: ${messageId}`);
    }

    // ------------------------------------------------------------
    // 正常終了ログ
    // ------------------------------------------------------------
    logEnd();

  } catch (e) {
    handleError(e);
  }
}
