/**
 * エラーハンドリング共通関数
 *
 * ・main() から catch 節で呼び出される想定
 * ・例外内容をログに出力
 * ・必要に応じて通知処理を行う
 *
 * ※ この関数内では例外を再 throw しない
 *    （エラー処理はここで完結させる方針）
 */
function handleError(error) {
  try {
    // ----------------------------------------------------------
    // 例外内容を文字列として整形
    // ----------------------------------------------------------
    // stack があればスタックトレースを優先して出力する
    // （デバッグ・運用時の調査を容易にするため）
    const message = error && error.stack
      ? error.stack
      : String(error);

    // ----------------------------------------------------------
    // エラーログ出力
    // ----------------------------------------------------------
    // 共通ログ関数を使用し、通常ログと区別する
    logError('unexpected error occurred');
    logError(message);

    // ----------------------------------------------------------
    // エラー通知（任意）
    // ----------------------------------------------------------
    // 通知要否は設定値により制御可能
    if (isNotifyOnError()) {
      notifyError(message);
    }

  } catch (e) {
    // ----------------------------------------------------------
    // エラーハンドラ自身で例外が発生した場合の最終防衛
    // ----------------------------------------------------------
    // ここでさらに例外を投げると原因調査が困難になるため、
    // GAS 標準 Logger のみに出力して処理を終了する
    Logger.log('FATAL: error occurred in handleError');
    Logger.log(e);
  }
}

/**
 * エラー発生時に通知を行うかどうかの判定
 *
 * ・将来的に config.gs の設定値と連動させる想定
 * ・現時点では通知なし（false）としている
 */
function isNotifyOnError() {
  return false;
}

/**
 * エラー通知処理（ひな形）
 *
 * ・現在はログ出力のみ
 * ・将来的に以下のような手段に拡張可能
 *   - GmailApp.sendEmail()
 *   - Google Chat Webhook
 *   - Slack Webhook
 */
function notifyError(message) {
  Logger.log('notify error: ' + message);
}
